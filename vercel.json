{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    { 
      "source": "/((?!api|static|.*\\..*).*)", 
      "destination": "/$1.html" 
    }
  ]
}
